<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox fx:id="CardRoot" alignment="CENTER" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="340.0" prefWidth="200.0" spacing="6.0" style="-fx-background-color: #1a1a2e; -fx-background-radius: 8; -fx-border-color: #4ecdc4; -fx-border-radius: 8; -fx-border-width: 1.5;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1">
   <children>
      <Label fx:id="name" alignment="CENTER" maxWidth="Infinity" style="-fx-font-weight: bold; -fx-font-size: 15px; -fx-background-color: trans; -fx-effect: dropshadow(gaussian, pink, 50, 0.7, 0, 0);" stylesheets="@../../Styles/Style.css" text="Item Name" textAlignment="CENTER" wrapText="true">
         <styleClass>
            <String fx:value="root" />
            <String fx:value="big-label" />
         </styleClass></Label>
      <ImageView fx:id="itemImage" fitHeight="110.0" fitWidth="140.0" pickOnBounds="true" preserveRatio="true" smooth="true" />
      <Label fx:id="type" alignment="CENTER" maxWidth="Infinity" style="-fx-text-fill: #4ecdc4; -fx-font-size: 11px; -fx-font-style: italic; -fx-background-color: trans; -fx-effect: dropshadow(gaussian, #00ffff, 40, 0.7, 0, 0);};" styleClass="root" stylesheets="@../../Styles/Style.css" text="Type" textAlignment="CENTER" />
      <Label fx:id="uses" alignment="CENTER" maxWidth="Infinity" style="-fx-text-fill: #ffd166; -fx-font-size: 11px; -fx-background-color: trans;" styleClass="root" stylesheets="@../../Styles/Style.css" text="Remaining uses" textAlignment="CENTER" wrapText="true" />
      <Label fx:id="rarity" alignment="CENTER" maxWidth="Infinity" style="-fx-text-fill: #f7d794; -fx-font-size: 11px; -fx-background-color: trans;" styleClass="root" stylesheets="@../../Styles/Style.css" text="Rarity" textAlignment="CENTER" />
      <Label fx:id="description" alignment="CENTER" maxWidth="Infinity" style="-fx-text-fill: #cccccc; -fx-font-size: 11px; -fx-background-color: trans;" styleClass="root" stylesheets="@../../Styles/Style.css" text="Description" textAlignment="CENTER" wrapText="true" />
      <Label fx:id="effects" alignment="CENTER" maxWidth="Infinity" style="-fx-text-fill: #c7f464; -fx-font-size: 11px; -fx-background-color: trans;" styleClass="root" stylesheets="@../../Styles/Style.css" text="Effects" textAlignment="CENTER" wrapText="true" VBox.vgrow="ALWAYS" />
      <Label fx:id="itemCost" alignment="CENTER" maxWidth="Infinity" style="-fx-text-fill: #a8ff78; -fx-font-size: 12px; -fx-font-weight: bold; -fx-background-color: trans;" styleClass="root" stylesheets="@../../Styles/Style.css" text="Cost" textAlignment="CENTER" />
      <Button fx:id="actionButton" maxWidth="Infinity" mnemonicParsing="false" onAction="#actionButton" style="-fx-background-color: #4ecdc4; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 4;" stylesheets="@../../Styles/Style.css" text="Use" textAlignment="CENTER">
         <font>
            <Font size="13.0" />
         </font>
         <styleClass>
            <String fx:value="root" />
            <String fx:value="small-label" />
         </styleClass>
      </Button>
   </children>
   <padding>
      <Insets bottom="12.0" left="10.0" right="10.0" top="10.0" />
   </padding>
</VBox>
