<AnchorPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="200.0" prefWidth="785.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1">
   <children>

      <!-- Outcome narrative text -->
      <Label fx:id="outcomeDescription" alignment="CENTER" layoutX="14.0" layoutY="14.0" prefWidth="757.0" text="" textAlignment="CENTER" wrapText="true" AnchorPane.leftAnchor="14.0" AnchorPane.rightAnchor="14.0" AnchorPane.topAnchor="14.0">
         <font><Font size="15.0" /></font>
      </Label>

      <!-- Stat change row -->
      <HBox fx:id="statChangeBox" alignment="CENTER" layoutX="14.0" layoutY="90.0" prefHeight="36.0" prefWidth="757.0" spacing="48.0" AnchorPane.leftAnchor="14.0" AnchorPane.rightAnchor="14.0" AnchorPane.topAnchor="90.0">

         <Label fx:id="creditsChangeLabel" textAlignment="CENTER">
            <font><Font size="14.0" /></font>
