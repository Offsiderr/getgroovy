            <String fx:value="root" />
            <String fx:value="big-label" />
         </styleClass>
      </Label>

      <HBox fx:id="lineupPane" layoutX="151.0" layoutY="76.0" prefHeight="240.0" prefWidth="977.0" spacing="8" style="-fx-background-color: trans;" stylesheets="@../../Styles/Style.css">
