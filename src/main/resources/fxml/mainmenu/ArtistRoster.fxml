      </ScrollPane>

      <Button layoutX="980.0" layoutY="662.0" mnemonicParsing="false" onAction="#returnToMainMenu" prefHeight="46.0" prefWidth="286.0" stylesheets="@../../Styles/Style.css" text="Return &amp; Save Lineup">
