            <String fx:value="root" />
            <String fx:value="tiny-label" />
         </styleClass></HBox>

      <Label layoutX="152.0" layoutY="341.0" style="-fx-background-color: trans;" styleClass="root" stylesheets="@../../Styles/Style.css" text="All Artists">
