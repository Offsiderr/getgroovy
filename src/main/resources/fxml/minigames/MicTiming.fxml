<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="485.0" prefWidth="785.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1">
    <children>
        <ImageView fitHeight="485.0" fitWidth="785.0" pickOnBounds="true">
            <image>
                <Image url="@../../images/MicTimingBackground.png" />
            </image>
        </ImageView>

        <Slider fx:id="timingSlider" layoutY="227.0" opacity="0.8" prefWidth="785.0" />

        <Label fx:id="missLeft" style="-fx-effect: dropshadow(gaussian, red, 12, 0.6, 0, 0);" text="|">
            <font><Font size="40.0" /></font></Label>
        <Label fx:id="goodLeft" style="-fx-effect: dropshadow(gaussian, orange, 12, 0.6, 0, 0);" text="|">
            <font><Font size="40.0" /></font></Label>
        <Label fx:id="perfect" style="-fx-effect: dropshadow(gaussian, lime, 12, 0.6, 0, 0);" text="|">
            <font><Font size="40.0" /></font></Label>
        <Label fx:id="goodRight" style="-fx-effect: dropshadow(gaussian, orange, 12, 0.6, 0, 0);" text="|">
            <font><Font size="40.0" /></font></Label>
        <Label fx:id="missRight" style="-fx-effect: dropshadow(gaussian, red, 12, 0.6, 0, 0);" text="|">
            <font><Font size="40.0" /></font></Label>

        <Button fx:id="hitButton" layoutX="330.0" layoutY="300.0" onAction="#handleHit" opacity="0.8" prefHeight="51.0" prefWidth="123.0" style="-fx-background-color: black;" styleClass="root" stylesheets="@../../Styles/Style.css" text="HIT!" textFill="WHITE" />

        <Label fx:id="resultLabel" layoutX="470.0" layoutY="300.0" prefHeight="160.0" prefWidth="250.0" style="-fx-background-color: trans;" styleClass="root" stylesheets="@../../Styles/Style.css" />

        <Label layoutX="185.0" layoutY="14.0" prefHeight="120.0" prefWidth="520.0" style="-fx-background-color: trans;" stylesheets="@../../Styles/Style.css" text="Hit the high note!" textFill="#f696ff">
            <styleClass>
                <String fx:value="root" />
                <String fx:value="big-label" />
            </styleClass>
        </Label>

        <ImageView fx:id="micThumb" fitHeight="40.0" fitWidth="40.0" layoutX="370.0" layoutY="214.0" pickOnBounds="true">
            <image>
                <Image url="@../../images/GoldMic.png" />
            </image>
        </ImageView>
      <Button fx:id="hitButton" layoutX="349.0" layoutY="441.0" mnemonicParsing="false" onAction="#handleHit" style="-fx-background-color: #301029;" stylesheets="@../../Styles/Style.css" text="Button" textFill="WHITE">
         <styleClass>
            <String fx:value="button" />
            <String fx:value="root" />
            <String fx:value="small-label" />
         </styleClass>
      </Button>

    </children>
</AnchorPane>
